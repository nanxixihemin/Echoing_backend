  private performReading() {
    this.readingResults = [];
    // жҙ—зүҢпјҡеӨҚеҲ¶дёҖд»ҪзүҢз»„е№¶йҡҸжңәжү“д№ұпјҢзЎ®дҝқдёҚдјҡжҠҪеҲ°йҮҚеӨҚзҡ„зү?
    const shuffled: TarotCard[] = [];
    for (let k = 0; k < this.tarotCards.length; k++) {
      shuffled.push(this.tarotCards[k]);
    }
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      const temp = shuffled[i];
      shuffled[i] = shuffled[j];
      shuffled[j] = temp;
    }
    // д»Һжҙ—еҘҪзҡ„зүҢдёӯдҫқж¬ЎеҸ?
    const count = this.readingModes[this.selectedMode].count;
    for (let i = 0; i < count; i++) {
      const card = shuffled[i];
      const isReversed = Math.random() > 0.7;
      this.readingResults.push({
        card: card,
        isReversed: isReversed,
        position: this.readingModes[this.selectedMode].positions[i]
      });
    }
    this.showResults = true;

    if (this.selectedMode === 0 && this.readingResults.length > 0) {
      this.currentCard = this.readingResults[0];
    } else {
      this.currentCard = undefined;
    }
  }

  private resetReading() {
    this.showResults = false;
    this.readingResults = [];
    this.currentCard = undefined;
  }

  private async showFullCelticCross() {
    let description = "еҮҜе°”зү№еҚҒеӯ—е®Ңж•ҙи§ЈиҜ?\n\n";
    for (let i = 0; i < this.readingResults.length; i++) {
      const result = this.readingResults[i];
      description += `${this.readingModes[2].positions[i]}: ${result.card.name} (${result.isReversed ? "йҖҶдҪҚ" :
        "жӯЈдҪҚ"})\n`;
      description += `еҗ«д№ү: ${result.isReversed ? result.card.reversedMeaning : result.card.meaning}\n\n`;
    }
    try {
      await promptAction.showDialog({
        title: "еҮҜе°”зү№еҚҒеӯ—е®Ңж•ҙи§ЈиҜ?,
        message: description,
      });
    } catch (error) {
      console.error("еҜ№иҜқжЎҶејӮеё?", error);
    }
  }

