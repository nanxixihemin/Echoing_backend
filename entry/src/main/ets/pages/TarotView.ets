        message: "иҜ·е…ҲжҠҪеҸ–еЎ”зҪ—зүҢеҶҚиҜ·жұӮ AI и§ЈиҜ»гҖ?,

      });
      return;
    }

    if (this.isAILoading) {
      return;
    }
    this.isAILoading = true;


    const theme = this.keyword.trim() || "дҪ еҪ“еүҚжңҖе…іеҝғзҡ„дәәз”ҹи®®йў?;
    const modeName = this.readingModes[this.selectedMode].name;

    let prompt = `гҖҗи§’иүІи®ҫе®ҡгҖ?
дҪ жҳҜдёҖдҪҚиө„ж·ұеЎ”зҪ—еҚ еҚңеёҲпјҢж“…й•ҝз»“еҗҲз”ЁжҲ·е…·дҪ“е…іеҲҮз»ҷеҮәж·ұеҲ»гҖҒжё©жҡ–дё” actionable зҡ„жҢҮеј?
гҖҗз”ЁжҲ·дё»йўҳгҖ?
жң¬ж¬ЎеҚ еҚңиҒҡз„ҰдәҺпјҡгҖ?{theme}гҖ?

гҖҗеҚ еҚңжЁЎејҸгҖ?
${modeName}

гҖҗжҠҪзүҢз»“жһңгҖ?
`;

    this.readingResults.forEach((result, index) => {
      const pos = this.readingModes[this.selectedMode].positions[index] || `з¬?{index + 1}дҪҚ`;
      const orientation = result.isReversed ? "йҖҶдҪҚ" : "жӯЈдҪҚ";
      const meaning = result.isReversed ? result.card.reversedMeaning : result.card.meaning;
      prompt += `- ${pos}пј?{result.card.name}пј?{orientation}пјү\n  еҗ«д№үпј?{meaning}\n`;
    });

    prompt += `\nгҖҗи§ЈиҜ»иҰҒжұӮгҖ?
1. жүҖжңүеҲҶжһҗеҝ…йЎ»зҙ§еҜҶеӣҙз»•гҖ?{theme}гҖҚеұ•ејҖпјҢдёҚеҸҜжіӣжіӣиҖҢи°ҲгҖ?
2. йҒҝе…ҚдҪҝз”ЁвҖңеҸҜиғҪвҖқвҖңд№ҹи®ёвҖқзӯүжЁЎзіҠиҜҚжұҮпјҢиҜӯж°”еқҡе®ҡиҖҢжё©жҹ”гҖ?
3. д»Һж•ҙдҪ“иғҪйҮҸгҖҒжҪңеңЁжҢ‘жҲҳгҖҒе…·дҪ“иЎҢеҠЁе»әи®®дёүж–№йқўи§ЈиҜ»гҖ?
4. жңҖеҗҺз”ЁдёҖеҸҘйј“еҠұзҡ„иҜқж”¶е°ҫпјҢи®©з”ЁжҲ·ж„ҹеҲ°иў«ж”ҜжҢҒгҖ?
5.дёҚдҪҝз”Ёд»»дҪ?Markdown ж јејҸпјҲеҰӮ **еҠ зІ—**гҖ?ж–ңдҪ“*гҖ?зӯүпјүпјҢдёҚиҰҒеңЁеӣһеӨҚжң«е°ҫж ҮжіЁеӯ—ж•°
зҺ°еңЁпјҢиҜ·ејҖе§ӢдҪ зҡ„дё“дёҡи§ЈиҜ»пјҡ`;

    
    const endpoint = AppConfig.AI_CHAT_COMPLETIONS_PROXY_URL;

    let reqBody: SiliconFlowReqBody = {
      model: AppConfig.AI_MODEL, 
      messages: [
        { role: "user", content: prompt }
      ],
      temperature: 0.7,
      max_tokens: 600
    };

    const httpRequest = http.createHttp();
    httpRequest.request(
      endpoint,
      {
        method: http.RequestMethod.POST,
        header: {
          'Content-Type': 'application/json'
        },
        extraData: JSON.stringify(reqBody),
        connectTimeout: 15000,
        readTimeout: 60000
      },
      (err, data) => {
        httpRequest.destroy();
        this.isAILoading = false;

        if (err) {
          console.error('зҪ‘з»ңиҜ·жұӮеӨұиҙҘ:', JSON.stringify(err));
          promptAction.showDialog({
            title: "вқ?зҪ‘з»ңй”ҷиҜҜ",
            message: "иҜ·жЈҖжҹҘзҪ‘з»ңиҝһжҺҘжҲ–зЁҚеҗҺйҮҚиҜ•гҖ?,

          });
          return;
        }

        if (data.responseCode !== 200) {
          console.error('HTTP й”ҷиҜҜ:', data.responseCode, data.result);
          let msg = "жңҚеҠЎеҷЁиҝ”еӣһејӮеёёгҖ?;
          if (data.responseCode === 401) msg = "API еҜҶй’Ҙж— ж•ҲпјҢиҜ·жЈҖжҹҘжҳҜеҗҰжӯЈзЎ®гҖ?;
          if (data.responseCode === 400) msg = "иҜ·жұӮж јејҸй”ҷиҜҜпјҢиҜ·зЎ®и®ӨжЁЎеһӢеҗҚз§°гҖ?;
          promptAction.showDialog({
            title: "вқ?жңҚеҠЎејӮеёё",
            message: msg,

          });
          return;
        }

        try {
          const aiResponse = JSON.parse(data.result as string) as SiliconFlowResponse;
          
          if (!aiResponse.choices || aiResponse.choices.length === 0) {
            console.error("е“Қеә”ејӮеёё (ж—?choices):", data.result);
            promptAction.showDialog({
              title: "Г— и§ЈиҜ»еӨұиҙҘ",
              message: "жңӘиҺ·еҸ–еҲ°жңүж•Ҳи§ЈиҜ»ж•°жҚ®пјҢиҜ·зЁҚеҗҺйҮҚиҜ•гҖ?,
            });
            return;
          }

          let aiResult = aiResponse.choices[0].message.content.trim();

          // жё…йҷӨ DeepSeek R1 жҖқиҖғй“ҫж Үзӯҫ
          aiResult = aiResult.replace(/<think>[\s\S]*?<\/think>/g, '');

          const cleanText = aiResult.replace(/\*\*(.*?)\*\*/g, '$1');
          const cleanText2 = cleanText.replace(/`/g, '').trim();

          router.pushUrl({
            url: 'pages/AIDialogPage',
            params: {
              interpretation: cleanText2,
              theme: this.keyword.trim() || "дҪ еҪ“еүҚжңҖе…іеҝғзҡ„дәәз”ҹи®®йў?
            }
          });
        } catch (parseError) {
          console.error('JSON и§ЈжһҗеӨұиҙҘ:', parseError);
          promptAction.showDialog({
            title: "Г— и§ЈиҜ»еӨұиҙҘ",
            message: "ж•°жҚ®и§ЈжһҗеӨұиҙҘпјҢиҜ·йҮҚиҜ•гҖ?,

          });
        }
      }
    );
  }
