  confirmLabel?: string;
  cancelLabel?: string;
  onConfirm?: () => void;
  onCancel?: () => void;
}

interface ReadingResult {
  card: TarotCard;
  isReversed: boolean;
  position: string;
}

interface ReadingMode {
  name: string;
  positions: string[];
  count: number;
}

// SiliconFlow / OpenAI API иҜ·жұӮдёҺе“Қеә”жҺҘеҸЈе®ҡд№?
interface SiliconFlowMessage {
  role: string;
  content: string;
}
interface SiliconFlowReqBody {
  model: string;
  messages: SiliconFlowMessage[];
  temperature: number;
  max_tokens: number;
}
interface SiliconFlowChoiceMessage {
  content: string;
}
interface SiliconFlowChoice {
  message: SiliconFlowChoiceMessage;
}
interface SiliconFlowResponse {
  choices: SiliconFlowChoice[];
}

